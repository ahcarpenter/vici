# Application
ENV=development
GIT_SHA=dev
WEBHOOK_BASE_URL=https://your-domain.com

# Database — must match .env.postgres.{env}
# For Docker Compose: use service name "postgres" as host
# For local dev outside Docker: use "localhost"
DATABASE_URL=postgresql+asyncpg://your_db_user:your_db_password@postgres:5432/your_db_name

# Temporal
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_TASK_QUEUE=vici-queue
CRON_SCHEDULE_PINECONE_SYNC=*/5 * * * *

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger-collector:4317
OTEL_SERVICE_NAME=vici

# Rate limiting
SMS_RATE_LIMIT_WINDOW_SECONDS=60
SMS_RATE_LIMIT_MAX=5

# Twilio
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_FROM_NUMBER=+15005550006

# External APIs
BRAINTRUST_API_KEY=your_braintrust_api_key
PINECONE_INDEX_HOST=https://your-index.svc.pinecone.io
PINECONE_API_KEY=your_pinecone_api_key
OPENAI_API_KEY=your_openai_api_key
