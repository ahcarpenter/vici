# Environment files — secrets
.env
.env.*

# Allow committed development defaults and examples
!.env.*.development
!.env.*.example

# Python bytecode
__pycache__/
*.py[cod]

# Local databases / artifacts
*.db

# Test / tooling caches
.pytest_cache/
.ruff_cache/

# OS / editor
.DS_Store
.claude/
