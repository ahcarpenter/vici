# Environment
ENV=development

# Database
DATABASE_URL=postgresql+asyncpg://vici:vici@localhost:5432/vici
POSTGRES_DB=vici
POSTGRES_USER=vici
POSTGRES_PASSWORD=vici

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_TASK_QUEUE=vici-queue
CRON_SCHEDULE_PINECONE_SYNC=*/5 * * * *

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=vici
GIT_SHA=dev

# Webhooks
WEBHOOK_BASE_URL=http://localhost:8000

# Rate limiting
SMS_RATE_LIMIT_WINDOW_SECONDS=60
SMS_RATE_LIMIT_MAX=5

# Grafana (local only — not a secret)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Pinecone (dev index)
PINECONE_INDEX_HOST=https://vici-dev-w5hl9ds.svc.aped-4627-b74a.pinecone.io

# Secrets — each developer supplies these locally (not committed)
# TWILIO_AUTH_TOKEN=
# TWILIO_ACCOUNT_SID=
# TWILIO_FROM_NUMBER=
# OPENAI_API_KEY=
# PINECONE_API_KEY=
