# -- Local Dev DB --------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://vici:vici@localhost:5432/vici
POSTGRES_DB=vici
POSTGRES_USER=vici
POSTGRES_PASSWORD=change_me

# -- Twilio --------------------------------------------------------------------
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# -- App -----------------------------------------------------------------------
WEBHOOK_BASE_URL=http://localhost:8000
ENV=development

# -- Inngest (local dev) -------------------------------------------------------
INNGEST_DEV=1
INNGEST_BASE_URL=http://localhost:8288
# Internal URL docker-compose uses to register the app with Inngest Dev Server.
# Change if you rename the 'app' service or use a different port.
INNGEST_APP_URL=http://app:8000

# -- Inngest (production -- set in Render dashboard, not here) -----------------
# INNGEST_SIGNING_KEY=your_inngest_signing_key
#   Obtain from: Inngest Cloud dashboard -> your app -> Signing Key
#   See README.md "Inngest Cloud Setup" for step-by-step instructions.
# INNGEST_EVENT_KEY=your_inngest_event_key
#   Obtain from: Inngest Cloud dashboard -> Manage -> Event Keys -> Create Key
# INNGEST_DEV=0
# INNGEST_BASE_URL=https://inn.gs

# -- OpenAI --------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key

# -- Pinecone ------------------------------------------------------------------
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_HOST=your_pinecone_index_host

# -- Braintrust ----------------------------------------------------------------
BRAINTRUST_API_KEY=your_braintrust_api_key

# -- Observability -------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=vici
GIT_SHA=dev
